# PostgreSQL connection
DATABASE_URL=
DB_NAME=leaderboard_db
DB_USER=username
DB_PASSWORD=password
DB_HOST=db
DB_PORT=5432

# Server settings
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=false

# Database initialization (useful for Docker startup)
AUTO_INIT_DB=true
DB_WAIT_TIMEOUT_SECONDS=90
DB_WAIT_INTERVAL_SECONDS=1

# Authentication
JWT_SECRET=change-me-in-production-please-use-a-long-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
